// ===================== SETUP =====================
void setup() {

  Serial.begin(115200);

  pinMode(Float_Switch1, INPUT_PULLUP);
  pinMode(Float_Switch2, INPUT_PULLUP);
  pinMode(Float_Switch3, INPUT_PULLUP);
  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);

  // Connect WiFi
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\nWiFi Connected");
  Serial.print("IP Address: ");
  Serial.println(WiFi.localIP());

  secured_client.setInsecure();

  server.on("/", handleRoot);
  server.on("/api/waterlevel", handleWaterLevel);
  server.on("/api/ultrasonic", handleUltrasonic);

  server.begin();
}


// ===================== LOOP =====================
void loop() {

  server.handleClient();

  // Read Ultrasonic
  long d = readUltrasonic();
  Serial.print("Ultrasonic: ");
  Serial.print(d);
  Serial.println(" cm");

  // Read Float Switch
  String currentLevel = getWaterLevel();
  Serial.print("Float Switch: ");
  Serial.println(currentLevel);

  // Check level change
  if (currentLevel != lastLevel) {
    lastLevel = currentLevel;
    alertSent = false;
  }

  // Alert when Red
  if (getWaterLevel() == "Red") {
    bot.sendMessage(CHAT_ID,
      "🚨 Flood Alert (FLOAT SWITCH RED)", "");
    delay(3000);
  }

  delay(2000);
}
