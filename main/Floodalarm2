// ========= CONFIGURATION =========
#define Float_Switch1 D1   // ระดับน้ำต่ำ (เขียว)
#define Float_Switch2 D2   // ระดับน้ำปานกลาง (เหลือง)
#define Float_Switch3 D3   // ระดับน้ำสูง (ส้ม)
#define TRIG_PIN D5        // Ultrasonic Trigger
#define ECHO_PIN D6        // Ultrasonic Echo
#define BUZZER_PIN D7      // Buzzer

const char* ssid = ">3";            // ชื่อ WiFi
const char* password = "12345678";  // รหัสผ่าน WiFi

// ======= Telegram Configuration =======
#define BOT_TOKEN "ใส่โทเคนบอทของคุณที่นี่"
#define CHAT_ID "ใส่ CHAT ID ของคุณที่นี่"

// สร้างอ็อบเจ็กต์ Telegram
WiFiClientSecure secured_client;
UniversalTelegramBot bot(BOT_TOKEN, secured_client);

// ======= Web Server =======
ESP8266WebServer server(80);

// ======= ตัวแปรสำหรับตรวจจับการแจ้งเตือน =======
String lastLevel = "";
unsigned long lastSend = 0;

// ======= ฟังก์ชันอ่านค่าจาก Ultrasonic =======
long readUltrasonic() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);
  long duration = pulseIn(ECHO_PIN, HIGH);
  long distance = duration * 0.034 / 2;
  return distance;
}

// ======= ฟังก์ชันอ่านค่าระดับน้ำ =======
String getWaterLevel() {
  int s1 = digitalRead(Float_Switch1);
  int s2 = digitalRead(Float_Switch2);
  int s3 = digitalRead(Float_Switch3);
  long distance = readUltrasonic();

  Serial.printf("Sensors: S1=%d, S2=%d, S3=%d, Distance=%ld cm\n", s1, s2, s3, distance);

  if (s1 == LOW) return "Green";
  else if (s2 == LOW) return "Yellow";
  else if (s3 == LOW) return "Orange";
  else return "Red";
}

// ======= ฟังก์ชันส่งข้อความ Telegram =======
void sendTelegram(String message) {
  if (WiFi.status() == WL_CONNECTED) {
    bot.sendMessage(CHAT_ID, message, "");
  }
}

