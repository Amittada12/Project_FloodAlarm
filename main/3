// ===== SETUP =====
void setup() {
  Serial.begin(115200);

  pinMode(Float_Switch1, INPUT_PULLUP);
  pinMode(Float_Switch2, INPUT_PULLUP);
  pinMode(Float_Switch3, INPUT_PULLUP);
  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);
  pinMode(BUZZER_PIN, OUTPUT);

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi Connected");

  secured_client.setInsecure();

  server.on("/", handleRoot);
  server.on("/api/waterlevel", handleWaterLevel);
  server.begin();
}

// ===== LOOP =====
void loop() {
  server.handleClient();

  if (getWaterLevel() == "Red") {
    digitalWrite(BUZZER_PIN, HIGH);
    bot.sendMessage(CHAT_ID, "🚨 Flood Alert (RED)", "");
    delay(3000);
  } else {
    digitalWrite(BUZZER_PIN, LOW);
  }
}
