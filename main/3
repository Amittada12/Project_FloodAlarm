// ===== Web Server =====
WebServer server(80);

// ===== Ultrasonic =====
long readUltrasonic() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);
  long duration = pulseIn(ECHO_PIN, HIGH, 30000);
  return duration * 0.034 / 2;
}

// ===== Water Level =====
String getWaterLevel() {
  if (digitalRead(Float_Switch1) == LOW) return "Green";
  if (digitalRead(Float_Switch2) == LOW) return "Yellow";
  if (digitalRead(Float_Switch3) == LOW) return "Orange";
  return "Red";
}

// ===== API =====
void handleWaterLevel() {
  server.send(200, "text/plain", getWaterLevel());
}

